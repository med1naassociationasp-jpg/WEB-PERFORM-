# ═══════════════════════════════════════════════════════════════════
# WhatsApp AI Agent Kit — Variables de entorno
# Copia este fichero a .env.local y rellena los valores
# ═══════════════════════════════════════════════════════════════════

# ─── OBLIGATORIO ─────────────────────────────────────────────────
# API key de OpenRouter (https://openrouter.ai/keys)
# Formato: sk-or-v1-...
# El bot NO arranca si esta variable está vacía.
OPENROUTER_API_KEY=

# Modelo de IA a usar
# Recomendados (NUNCA uses modelos :free en producción — dan 429 con 2+ conversaciones):
#   openai/gpt-4o-mini       ← recomendado, equilibrio precio/calidad
#   anthropic/claude-haiku-4-5
#   google/gemini-2.5-flash
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── TOOLS (opcionales) ──────────────────────────────────────────
# Webhook de Google Apps Script para guardar leads en Google Sheets
# Si vacío, la tool guardarLead queda inactiva (devuelve ok:false)
GOOGLE_SHEETS_WEBHOOK_URL=

# URL de Cal.com o Calendly para agendar llamadas
# Ej: https://cal.com/tu-usuario/diagnostico
# Si vacío, la tool agendar queda inactiva
CAL_BOOKING_URL=

# ─── PRODUCCIÓN (opcionales) ─────────────────────────────────────
# Puerto del dashboard Next.js (default: 3000)
PORT=3000

# Nivel de log del bot: silent | error | warn | info | debug
LOG_LEVEL=info
